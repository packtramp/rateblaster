rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Subscribers - client can create/update (signup, re-subscribe, unsubscribe)
    match /subscribers/{doc} {
      allow create: if request.resource.data.keys().hasAll(['email', 'active']);
      allow read: if true;
      allow update: if true;
      allow delete: if false;
    }
    // Rate history - anyone can read (public display), only server writes
    match /rateHistory/{doc} {
      allow read: if true;
      allow write: if false;
    }
  }
}
